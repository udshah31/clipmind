# Copy to .env and fill in. .env is gitignored.

# --- Local stack (defaults match docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://clipmind:clipmind@localhost:5432/clipmind
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO locally; Cloudflare R2 in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=clipmind-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# --- AI providers (leave blank in Phase 0; fill in Phase 3+) ---
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Auth (Phase 2) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Observability (optional) ---
SENTRY_DSN=

# --- App config ---
APP_ENV=local
LOG_LEVEL=info
